# Maintainer: Bruno Goncalves <bigbruno@gmail.com>

pkgname=biglinux-browser-selector
pkgver=$(date +%y.%m.%d)
pkgrel=$(date +%H%M)
arch=('any')
license=('GPL')
pkgdesc="Choose your default web browser with a modern GTK4 interface."
depends=('gtk4' 'python' 'polkit' 'python-yaml')
url="https://github.com/biglinux/$pkgname"

source=("$pkgname")
md5sums=(SKIP)

if [ -e "${pkgname}.install" ]; then
    install=${pkgname}.install
fi

package() {
    # Copy files
    if [ -d "${srcdir}/${pkgname}/usr" ]; then
        cp -r "${srcdir}/${pkgname}/usr" "${pkgdir}/"
    fi

    if [ -d "${srcdir}/${pkgname}/etc" ]; then
        cp -r "${srcdir}/${pkgname}/etc" "${pkgdir}/"
    fi

    if [ -d "${srcdir}/${pkgname}/opt" ]; then
        cp -r "${srcdir}/${pkgname}/opt" "${pkgdir}/"
    fi
}
